rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Yardımcı: Kullanıcı member/admin rolünde mi? (sadece role kullanılır)
    function hasMemberRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'member'
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Kullanıcı profilleri: Sadece kendi profilini oku/yaz
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Tarifler: Member kendi tarifini yazabilir; public tarifler herkese açık okuma
    match /recipes/{recipeId} {
      allow read: if resource == null
        || resource.data.isPublic == true
        || (request.auth != null && resource.data.ownerUid == request.auth.uid);
      allow create: if request.auth != null && hasMemberRole();
      allow update, delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // Sosyal postlar: Sadece sahibi silebilir/güncelleyebilir
    match /socialPosts/{postId} {
      allow read: if resource.data.isPublic == true;
      allow create: if request.auth != null && hasMemberRole();
      allow update, delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // Beğeniler: Giriş yapmış herkes ekleyebilir/silebilir (kendi like'ı)
    match /likes/{likeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Yorumlar: Giriş yapmış herkes ekleyebilir; sadece sahibi silebilir
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Kaydetmeler: Kullanıcı kendi save'lerini yönetir
    match /saves/{saveId} {
      allow read, write: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // Koleksiyonlar: Kullanıcı kendi koleksiyonlarını yönetir
    match /collections/{collectionId} {
      allow read, write: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // Kategoriler: Member okuyup yazabilir
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null && hasMemberRole();
    }

    // Listeler: Sadece member erişebilir (userId şu an yok, member-only)
    match /lists/{listId} {
      allow read, write: if request.auth != null && hasMemberRole();
    }
  }
}
