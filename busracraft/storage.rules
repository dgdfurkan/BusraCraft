rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /recipes/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /users/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
